{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install": {
      "inputs": [
        { "step": "packages:mise" },
        { "local": true, "include": ["."] }
      ],
      "commands": [
        "python -m venv /app/.venv",
        "/app/.venv/bin/pip install -r /app/backend/requirements.txt"
      ]
    }
  },
  "deploy": {
    "inputs": [
      {
        "step": "packages:mise",
        "include": ["/mise/shims", "/mise/installs"]
      },
      { "step": "install", "include": ["/app/.venv"] },
      { "local": true, "include": ["."] }
    ],
    "aptPackages": ["libgomp1"],
    "startCommand": "cd /app/backend && /app/.venv/bin/uvicorn main:app --host 0.0.0.0 --port $PORT"
  }
}
