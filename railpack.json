{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.11"
  },
  "steps": {
    "install": {
      "inputs": [
        { "step": "packages:mise" },
        { "local": true, "include": ["."] }
      ],
      "commands": ["pip install -r /app/backend/requirements.txt"]
    }
  },
  "deploy": {
    "startCommand": "cd /app/backend && uvicorn main:app --host 0.0.0.0 --port $PORT"
  }
}
