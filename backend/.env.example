# Copy this file to backend/.env and fill in real values
# Never commit backend/.env to the repo

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

DATABENTO_API_KEY=your-databento-api-key-here

TRADIER_API_KEY=your-tradier-api-key-here
TRADIER_ACCOUNT_ID=your-tradier-account-id-here
TRADIER_SANDBOX=true

POLYGON_API_KEY=your-polygon-api-key-here

REDIS_URL=redis://localhost:6379

ENVIRONMENT=development
