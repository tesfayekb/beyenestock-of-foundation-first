# Copy this file to backend/.env and fill in real values
# Never commit backend/.env to the repo

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

DATABENTO_API_KEY=your-databento-api-key-here

TRADIER_API_KEY=your-tradier-api-key-here
TRADIER_ACCOUNT_ID=your-tradier-account-id-here
TRADIER_SANDBOX=true

POLYGON_API_KEY=your-polygon-api-key-here

REDIS_URL=redis://localhost:6379

ENVIRONMENT=development

# ─────────────────────────────────────────────────────────────────
# External alerting transports (HARD-B / T-ACT-063).
# At least ONE must be set or alerting is silently disabled.
# Both can be set together for belt-and-suspenders redundancy.
# ─────────────────────────────────────────────────────────────────

# Slack webhook (preferred on Railway — HTTPS:443 egress always works,
# unlike outbound SMTP which Railway blocks by default).
# Set up: Slack workspace → Apps → "Incoming Webhooks" → add to a
# channel → copy URL.
ALERT_SLACK_WEBHOOK_URL=

# Gmail SMTP (legacy; works locally but fails on Railway with
# `[Errno 101] Network is unreachable` — kept for non-Railway
# environments and as belt-and-suspenders).
# Gmail App Password required (NOT account password):
#   Google Account → Security → 2-Step Verification → App Passwords
ALERT_EMAIL=
ALERT_GMAIL_APP_PASSWORD=
# ALERT_FROM_EMAIL defaults to ALERT_EMAIL when unset.
ALERT_FROM_EMAIL=

# ─────────────────────────────────────────────────────────────────
# Training-script overrides (operator-local; not read by uvicorn).
# ─────────────────────────────────────────────────────────────────
# Bypass the labeled-sessions auto-gate in
# backend/scripts/train_direction_model.py for the operator's
# one-time bootstrap training run. Default is 90 (keeps the gate
# protective for any future scheduled invocation). Set to 0 only
# when you intentionally want to train the first model before the
# live system has accumulated 90 labeled sessions:
#
#   LGBM_MIN_LABELED_SESSIONS=0 python -m scripts.train_direction_model
#
# LGBM_MIN_LABELED_SESSIONS=90
